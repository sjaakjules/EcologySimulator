{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "playwright.config.ts",
    "vitest.config.ts",
    "eslint.config.mjs"
  ],
  "exclude": ["node_modules"]
}
