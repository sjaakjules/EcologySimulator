{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev:server",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready - started server on|Ready in .*|Local:\\s+http://localhost:3000"
        }
      }
    }
  ]
}
